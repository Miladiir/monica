{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "digest"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "ignoreTests": true
    }
  ],
  "minimumReleaseAge": "7 days"
}
